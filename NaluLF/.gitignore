# ==============================
# FILE: .gitignore
# ==============================

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Node
node_modules/
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs / cache
dist/
build/
out/
coverage/
.cache/
.parcel-cache/
.eslintcache

# Env
.env
.env.*
!.env.example

# Capacitor / iOS build artifacts
ios/
android/
.capacitor/

# Xcode
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Misc
*.bak
*.swp
*.tmp